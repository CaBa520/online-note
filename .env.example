DATABASE_URL="postgresql://onlinenote:onlinenote_dev@localhost:5432/onlinenote"
AUTH_SECRET="替换为随机生成的密钥"
REDIS_URL="redis://localhost:6379"

# SMTP 邮件配置（可选，不配则用 Ethereal 测试邮箱）
# QQ邮箱: SMTP_HOST=smtp.qq.com SMTP_PORT=465 SMTP_USER=你的QQ@qq.com SMTP_PASS=授权码
# 163邮箱: SMTP_HOST=smtp.163.com SMTP_PORT=465 SMTP_USER=你的邮箱@163.com SMTP_PASS=授权码
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_USER=你的邮箱@gmail.com SMTP_PASS=应用密码
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Online Note <noreply@example.com>"

# 留空自动使用请求域名（支持内网穿透）
AUTH_URL=
NEXT_PUBLIC_APP_URL=
