DATABASE_URL=           # PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db)
AUTH_SECRET=            # NextAuth secret (generate: openssl rand -base64 32)
AUTH_URL=               # Production URL (https://yourdomain.com)
REDIS_URL=              # Upstash Redis URL (e.g. redis://user:pass@host:6379)
RESEND_API_KEY=         # Resend API key for emails
NEXT_PUBLIC_APP_URL=    # Public app URL (https://yourdomain.com)
